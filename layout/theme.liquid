<!DOCTYPE html>
<html lang="{{ shop.locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }}</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
  <header class="blur-glass-header">
    <div class="header-container">
      <div class="logo">
        <a href="/">{{ shop.name }}</a>
      </div>
      <nav class="main-nav">
        <ul>
          <li><a href="/">{{ 'general.home' | t }}</a></li>
          <li><a href="/collections">{{ 'general.shop' | t }}</a></li>
          <li><a href="/pages/about">{{ 'general.about' | t }}</a></li>
          <li><a href="/pages/contact">{{ 'general.contact' | t }}</a></li>
        </ul>
      </nav>
      <div class="header-actions">
        <a href="/search" class="search-icon" title="{{ 'general.search' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </a>
        <a href="/cart" class="cart-icon" title="{{ 'general.cart.title' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <main>
    {{ content_for_layout }}
  </main>

  <footer class="premium-footer">
    <div class="footer-container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>{{ shop.name }}</h3>
          <p>{{ 'benefits.customer_support_desc' | t }}</p>
          <div style="margin-top: 1.5rem;">
            {% render 'social-icons' %}
          </div>
        </div>

        <div class="footer-section">
          <h4>{{ 'footer.about' | t }}</h4>
          <ul>
            <li><a href="/pages/about">{{ 'footer.about' | t }}</a></li>
            <li><a href="/collections">{{ 'general.shop' | t }}</a></li>
            <li><a href="/pages/contact">{{ 'footer.contact' | t }}</a></li>
          </ul>
        </div>

        <div class="footer-section">
          <h4>{{ 'footer.faq' | t }}</h4>
          <ul>
            <li><a href="/policies/privacy-policy">{{ 'footer.privacy' | t }}</a></li>
            <li><a href="/policies/terms-of-service">{{ 'footer.terms' | t }}</a></li>
            <li><a href="/policies/shipping-policy">{{ 'footer.shipping' | t }}</a></li>
            <li><a href="/policies/refund-policy">{{ 'footer.returns' | t }}</a></li>
          </ul>
        </div>

        <div class="footer-section">
          <h4>{{ 'footer.newsletter.title' | t }}</h4>
          <p class="newsletter-description">{{ 'footer.newsletter.description' | t }}</p>
          <form class="newsletter-form" method="post" action="/contact">
            <input 
              type="email" 
              name="email" 
              placeholder="{{ 'footer.newsletter.placeholder' | t }}" 
              required
              class="newsletter-input"
            >
            <button type="submit" class="newsletter-btn">{{ 'footer.newsletter.subscribe' | t }}</button>
          </form>
        </div>
      </div>

      <div class="footer-divider"></div>

      <div class="footer-bottom">
        <p class="copyright">
          {{ 'footer.copyright' | t }}
        </p>
        <div class="payment-methods">
          <span class="payment-label">{{ 'general.site_title' | t }}:</span>
          <svg width="32" height="20" viewBox="0 0 32 20" xmlns="http://www.w3.org/2000/svg" style="margin-left: 0.5rem;">
            <rect width="32" height="20" rx="4" fill="#1434CB"/>
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="white" font-size="10" font-weight="bold">VISA</text>
          </svg>
        </div>
      </div>
    </div>
  </footer>

  <style>
    .premium-footer {
      background: linear-gradient(135deg, #121212 0%, #1a1a1a 100%);
      color: var(--color-white);
      padding: 4rem 1.5rem 2rem;
      margin-top: 4rem;
    }

    .footer-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    .footer-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 3rem;
      margin-bottom: 3rem;
    }

    .footer-section h3,
    .footer-section h4 {
      color: var(--color-white);
      margin-bottom: 1rem;
      font-size: 1rem;
      font-weight: 600;
    }

    .footer-section h3 {
      font-size: 1.25rem;
      font-weight: 700;
    }

    .footer-section p {
      color: #ccc;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .footer-section ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-section ul li {
      margin-bottom: 0.75rem;
    }

    .footer-section ul a {
      color: #ccc;
      text-decoration: none;
      font-size: 0.9rem;
      transition: color var(--transition-standard);
    }

    .footer-section ul a:hover {
      color: var(--color-white);
    }

    .newsletter-description {
      font-size: 0.85rem !important;
      margin-bottom: 1rem !important;
    }

    .newsletter-form {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .newsletter-input {
      padding: 0.75rem 1rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: var(--radius-medium);
      background: rgba(255, 255, 255, 0.1);
      color: var(--color-white);
      font-size: 0.9rem;
      transition: all var(--transition-standard);
    }

    .newsletter-input::placeholder {
      color: rgba(255, 255, 255, 0.6);
    }

    .newsletter-input:focus {
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(255, 255, 255, 0.4);
      outline: none;
    }

    .newsletter-btn {
      padding: 0.75rem 1.5rem;
      background: var(--color-blue);
      color: var(--color-white);
      border: none;
      border-radius: var(--radius-medium);
      font-weight: 600;
      cursor: pointer;
      transition: all var(--transition-standard);
    }

    .newsletter-btn:hover {
      background: #0056CC;
      transform: translateY(-2px);
    }

    .footer-divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 2rem 0;
    }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1rem;
    }

    .copyright {
      color: #999;
      font-size: 0.85rem;
      margin: 0;
    }

    .payment-methods {
      display: flex;
      align-items: center;
      gap: 1rem;
      color: #999;
      font-size: 0.85rem;
    }

    .payment-label {
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .premium-footer {
        padding: 2.5rem 1rem 1.5rem;
      }

      .footer-content {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .footer-bottom {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
      }
    }
  </style>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>