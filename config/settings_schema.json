[
  {
    "name": "Theme Settings",
    "settings": [
      {
        "type": "select",
        "id": "theme_mode",
        "label": "Theme Mode",
        "options": [
          {
            "value": "minimalist",
            "label": "Minimalist Mode"
          },
          {
            "value": "vibrant",
            "label": "Vibrant Mode"
          }
        ],
        "default": "vibrant"
      },
      {
        "type": "color",
        "id": "primary_color",
        "label": "Primary Color",
        "default": "#007AFF"
      },
      {
        "type": "color",
        "id": "secondary_color",
        "label": "Secondary Color",
        "default": "#121212"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#FFFFFF"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading Font",
        "default": "plus_jakarta_sans_n4"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body Font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Section Spacing (px)",
        "min": 60,
        "max": 150,
        "step": 10,
        "default": 100
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_sticky_header",
        "label": "Enable Sticky Header",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_blur_glass",
        "label": "Enable Blur Glass Effect",
        "default": true
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_newsletter",
        "label": "Enable Newsletter Signup",
        "default": true
      },
      {
        "type": "text",
        "id": "copyright_text",
        "label": "Copyright Text",
        "default": "© {{ shop.name }}. All rights reserved."
      }
    ]
  }
]