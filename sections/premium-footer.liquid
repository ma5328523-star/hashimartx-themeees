{{ 'section-premium-footer.css' | asset_url | stylesheet_tag }}

<footer class="premium-footer" data-section-type="premium-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-column">
        <h3>{{ shop.name }}</h3>
        <p>Premium products for the modern lifestyle.</p>
        <div class="social-links">
          <a href="#">Facebook</a>
          <a href="#">Instagram</a>
          <a href="#">Twitter</a>
        </div>
      </div>
      <div class="footer-column">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/new-arrivals">New Arrivals</a></li>
          <li><a href="/collections/sale">Sale</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>Support</h4>
        <ul>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/shipping">Shipping Info</a></li>
          <li><a href="/pages/returns">Returns</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>{{ section.settings.newsletter_title }}</h4>
        <p>{{ section.settings.newsletter_subtitle }}</p>
        <form class="newsletter-form">
          <input type="email" placeholder="Enter your email" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Premium Footer",
  "settings": [
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Join Our Community"
    },
    {
      "type": "textarea",
      "id": "newsletter_subtitle",
      "label": "Newsletter Subtitle",
      "default": "Get exclusive access to new products and special offers"
    }
  ],
  "presets": [
    {
      "name": "Premium Footer"
    }
  ]
}
{% endschema %}